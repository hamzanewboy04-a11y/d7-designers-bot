# Telegram bot token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated list of admin Telegram IDs (initial seed admins)
ADMIN_IDS=123456789,987654321

# SQLite database path (legacy / local fallback)
DB_PATH=d7_bot.sqlite3

# Shared PostgreSQL URL (future / preferred for multi-service deployment)
DATABASE_URL=

# Hour (UTC) to send daily reports (0-23)
REPORT_HOUR_UTC=8

# Google Sheets integration (optional)
GOOGLE_SHEET_ID=your_google_sheet_id_here
# Path to service account JSON file, or inline JSON string
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service_account.json
